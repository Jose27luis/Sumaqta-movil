{
  "expo": {
    "name": "Sumaqta",
    "slug": "sumaqtamovil",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/images/amantix-icon.png",
    "scheme": "sumaqtamovil",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/amantix-icon.png"
    },
    "android": {
      "package": "cloud.insoft.sumaqtamovil",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/amantix-icono.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/amantix-icono.png",
          "imageWidth": 180,
          "android": {
            "image": "./assets/images/amantix-icono.png",
            "imageWidth": 180
          }
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "505211cb-10e4-42d5-b72a-31264897fd34"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "jose_teco"
  }
}
